load("@rules_foreign_cc//foreign_cc:defs.bzl", "cmake")

package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

cmake(
    name = "tcg_tpm",
    lib_source = ":all_srcs",
    working_directory = "TPMCmd",
    cache_entries = {
        "CMAKE_BUILD_TYPE": "Debug",
    },
    install = True,
    out_binaries = ["Simulator"],
)
